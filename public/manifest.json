{
  "manifest_version": 3,
  "name": "Clozemaster Multilingual Helper",
  "version": "0.1.0",
  "description": "Translate Clozemaster meanings into your native language.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.clozemaster.com/*",
    "https://translation.googleapis.com/*",
    "https://api.deepl.com/*",
    "https://api-free.deepl.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.clozemaster.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "Clozemaster Multilingual Helper",
    "default_popup": "popup.html"
  }
}
